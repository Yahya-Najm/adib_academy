generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GENERAL_MANAGER
  MANAGER
  TEACHER
  STAFF
}

enum PaymentType {
  MONTHLY_SALARY      // Managers and Staff
  PER_CLASS           // Teachers — fixed rate per section taught
  REVENUE_PERCENTAGE  // Teachers — percentage of student fees per class
  FIXED_HOURS         // Teachers — hourly rate per section taught (each section = 1 hour)
}

enum StaffPaymentStatus {
  DRAFT
  PDF_GENERATED
  FINALIZED
}

enum TeacherPaymentStatus {
  DRAFT
  PDF_GENERATED
  FINALIZED
}

enum ClassStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EducationLevel {
  BELOW_GRADE_6
  GRADE_6_AND_ABOVE
  SCHOOL_GRADUATE
  BACHELOR
  MASTERS
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

enum ReportKind {
  SIMPLE      // informational note, no action needed
  ACTIONABLE  // requires manager to do something and mark done/undone
}

enum ExamType {
  REGULAR
  FINAL
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  MANUAL
  STUDENT_PAYMENT
  PRODUCT_SALE
  STAFF_SALARY
  TEACHER_PAYMENT
}

model Branch {
  id              String             @id @default(cuid())
  name            String
  address         String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  users           User[]
  students        Student[]
  courseTemplates CourseTemplate[]
  courseClasses   CourseClass[]
  products        Product[]
  productSales    ProductSale[]
  transactions    Transaction[]
  officialHolidays OfficialHoliday[]
  weeklyHolidays  WeeklyHoliday[]
  staffAttendances StaffAttendance[]
  attendanceReports AttendanceReport[]
  attendanceFinalizations AttendanceFinalization[]
  classMonthFinalizations ClassMonthFinalization[]
  staffPayments     StaffPayment[]
  teacherPayments   TeacherPayment[]
}

/// A course template defined by the General Manager
/// branchId = null means it applies to all branches
model CourseTemplate {
  id             String        @id @default(cuid())
  name           String
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id])
  monthlyFee     Float
  durationMonths Int
  numSections    Int           @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  courseClasses  CourseClass[]
}

/// A running class instance started by a manager
model CourseClass {
  id               String             @id @default(cuid())
  classId          String?            @unique  // e.g. "english-grammar-a4f2" — auto-generated on create
  courseTemplateId String
  courseTemplate   CourseTemplate     @relation(fields: [courseTemplateId], references: [id])
  branchId         String
  branch           Branch             @relation(fields: [branchId], references: [id])
  managerId        String
  manager          User               @relation("ManagedClasses", fields: [managerId], references: [id])
  startDate        DateTime
  classTime        String             // "09:00"
  offDays          String[]           // ["Friday", "Saturday"] — weekly recurring off days
  status           ClassStatus        @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  sections         ClassSection[]
  exams            Exam[]
  courseEnrollments CourseEnrollment[]
  studentAttendances StudentAttendance[]
  classHolidays    ClassHoliday[]
  monthFinalizations ClassMonthFinalization[]
}

/// One section of a CourseClass, taught by a single teacher
model ClassSection {
  id            String      @id @default(cuid())
  courseClassId String
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  sectionNumber Int
  sectionName   String?     // e.g. "Book", "Grammar", "Computer"
  teacherId     String
  teacher       User        @relation("TeachingSections", fields: [teacherId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  teacherAttendances TeacherAttendance[]
  studentEnrollments CourseEnrollment[]
  studentAttendances StudentAttendance[]

  @@unique([courseClassId, sectionNumber])
}

/// An exam for a CourseClass
model Exam {
  id                    String      @id @default(cuid())
  courseClassId         String
  courseClass           CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  title                 String
  date                  DateTime
  description           String?
  examType              ExamType    @default(REGULAR)
  classMonth            Int?        // which month of the class this exam falls in (auto-detected)
  proctorId             String?     // the teacher/manager who supervised the exam
  proctor               User?       @relation("ProctorExams", fields: [proctorId], references: [id])
  scoringFinalized      Boolean     @default(false)
  scoringFinalizedAt    DateTime?
  scoringFinalizedById  String?
  scoringFinalizedBy    User?       @relation("FinalizedExamScoring", fields: [scoringFinalizedById], references: [id])
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  examScores            ExamScore[]
}

model User {
  id                String           @id @default(cuid())
  userId            String?          @unique  // e.g. "john-doe-a4f2" — auto-generated for all roles
  name              String
  email             String?          @unique
  password          String
  role              Role
  /// For STAFF role only — e.g. "Cleaner", "Cook", "Security"
  staffType         String?
  active            Boolean          @default(true)
  branchId          String?
  branch            Branch?          @relation(fields: [branchId], references: [id])
  createdBy         String?
  // Payment
  paymentType       PaymentType?
  monthlySalary     Float?           // For MONTHLY_SALARY
  perClassRate      Float?           // For PER_CLASS teachers
  revenuePercentage Float?           // For REVENUE_PERCENTAGE teachers
  hourlyRate        Float?           // For FIXED_HOURS teachers
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  // Relations
  managedClasses    CourseClass[]    @relation("ManagedClasses")
  teachingSections  ClassSection[]   @relation("TeachingSections")
  createdStudents   Student[]        @relation("CreatedStudents")
  productSales      ProductSale[]
  transactions      Transaction[]
  staffAttendances  StaffAttendance[]
  writtenReports    AttendanceReport[] @relation("WrittenReports")
  teacherWrittenReports AttendanceReport[] @relation("TeacherWrittenReports")
  resolvedReports   AttendanceReport[] @relation("ResolvedReports")
  finalizedDays     AttendanceFinalization[] @relation("FinalizedDays")
  teacherFinalizedDays AttendanceFinalization[] @relation("TeacherFinalizedDays")
  proctorExams      Exam[]           @relation("ProctorExams")
  finalizedExamScoring Exam[]        @relation("FinalizedExamScoring")
  finalizedClassMonths ClassMonthFinalization[] @relation("FinalizedClassMonths")
  staffPayments     StaffPayment[]   @relation("UserStaffPayments")
  staffPaymentsFinalized StaffPayment[] @relation("StaffPaymentFinalizer")
  teacherPayments   TeacherPayment[] @relation("UserTeacherPayments")
  teacherPaymentsFinalized TeacherPayment[] @relation("TeacherPaymentFinalizer")
}

model Student {
  id           String             @id @default(cuid())
  studentId    String?            @unique  // e.g. "john-doe-a4f2", auto-generated
  firstName    String
  lastName     String
  age          Int
  phone        String?
  email        String?            @unique
  education    EducationLevel
  address      String?
  parentPhone1 String?
  parentPhone2 String?
  active       Boolean            @default(true)
  branchId     String?
  branch       Branch?            @relation(fields: [branchId], references: [id])
  createdById  String?
  createdBy    User?              @relation("CreatedStudents", fields: [createdById], references: [id])
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  enrollments  CourseEnrollment[]
  examScores   ExamScore[]
  studentAttendances StudentAttendance[]
}

/// A student enrolled in a CourseClass, assigned to a specific ClassSection
model CourseEnrollment {
  id              String           @id @default(cuid())
  studentId       String
  student         Student          @relation(fields: [studentId], references: [id])
  courseClassId   String
  courseClass     CourseClass      @relation(fields: [courseClassId], references: [id])
  classSectionId  String
  classSection    ClassSection     @relation(fields: [classSectionId], references: [id])
  enrolledAt      DateTime         @default(now())
  status          EnrollmentStatus @default(ACTIVE)
  monthlyPayments MonthlyPayment[]

  @@unique([studentId, courseClassId])
}

/// Monthly payment record for a CourseEnrollment
model MonthlyPayment {
  id           String           @id @default(cuid())
  enrollmentId String
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  monthNumber  Int              // 1-based: month 1, 2, 3...
  amount       Float
  dueDate      DateTime
  paidAt       DateTime?
  status       PaymentStatus    @default(PENDING)
  fromDate     DateTime?        // date student joined (set on month 1 only, for mid-month joins)
  paidAmount   Float?           // actual amount collected (for partial payments)
  feesRefId    String?          // manager-entered reference/receipt ID
  discounted   Boolean          @default(false) // true = "time passed discount" applied
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Product {
  id        String        @id @default(cuid())
  name      String
  price     Float
  stock     Int           @default(0)
  branchId  String
  branch    Branch        @relation(fields: [branchId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sales     ProductSale[]
}

model ProductSale {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  totalPrice  Float    // quantity × price at time of sale
  soldById    String
  soldBy      User     @relation(fields: [soldById], references: [id])
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  createdAt   DateTime @default(now())
}

model Transaction {
  id              String            @id @default(cuid())
  trackingNumber  String?           @unique  // required for MANUAL, null for system-generated
  type            TransactionType   @default(EXPENSE)
  sourceType      TransactionSource @default(MANUAL)
  sourceId        String?           // reference to originating record (paymentId, saleId, etc.)
  category        String            // free text + datalist presets
  description     String?
  amount          Float
  transactionDate DateTime          // the actual date the money moved
  branchId        String
  branch          Branch            @relation(fields: [branchId], references: [id])
  recordedById    String
  recordedBy      User              @relation(fields: [recordedById], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ExamScore {
  id        String   @id @default(cuid())
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  score     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
}

/// Official holidays created by GM — null branchId = applies to all branches
model OfficialHoliday {
  id        String   @id @default(cuid())
  name      String   // reason/title e.g. "National Day", "School Event"
  date      DateTime @db.Date
  branchId  String?  // null = global; set = branch-specific
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentAttendance {
  id             String       @id @default(cuid())
  courseClassId  String
  courseClass    CourseClass  @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  date           DateTime     @db.Date
  present        Boolean
  isLate         Boolean      @default(false)

  @@unique([classSectionId, studentId, date])
}

model TeacherAttendance {
  id             String       @id @default(cuid())
  classSectionId String
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  teacherId      String
  date           DateTime     @db.Date
  present        Boolean
  isLate         Boolean      @default(false)

  @@unique([classSectionId, teacherId, date])
}

/// GM-set recurring weekly off-days — null branchId = all branches
model WeeklyHoliday {
  id        String   @id @default(cuid())
  dayOfWeek String   // "Monday" … "Sunday"
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())

  @@unique([dayOfWeek, branchId])
}

/// Manager-set one-off holiday for a specific class
model ClassHoliday {
  id            String      @id @default(cuid())
  courseClassId String
  courseClass   CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  date          DateTime    @db.Date
  reason        String
  createdAt     DateTime    @default(now())

  @@unique([courseClassId, date])
}

/// Daily attendance record for STAFF role users
model StaffAttendance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  date      DateTime @db.Date
  present   Boolean
  isLate    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

/// Reports written by managers OR teachers about staff, teachers, students, or classes
/// reportKind: SIMPLE = informational note; ACTIONABLE = requires manager action + done/undone
/// isAutomatic: true = auto-created from Late/Absent checkbox; false = manually written
/// Exactly one of managerId / teacherId is set (the author)
model AttendanceReport {
  id               String      @id @default(cuid())
  date             DateTime    @db.Date
  branchId         String
  branch           Branch      @relation(fields: [branchId], references: [id])
  managerId        String?
  manager          User?       @relation("WrittenReports", fields: [managerId], references: [id])
  teacherId        String?
  teacher          User?       @relation("TeacherWrittenReports", fields: [teacherId], references: [id])
  subjectType      String      // "STAFF" | "TEACHER" | "STUDENT" | "CLASS"
  subjectId        String      // userId for STAFF/TEACHER, studentId for STUDENT, courseClassId for CLASS
  isAutomatic      Boolean     @default(false)
  reportKind       ReportKind  @default(SIMPLE)
  reportType       String      // "LATE" | "ABSENT" | free-text category for manual
  content          String?     // body text — optional for auto, required for manual
  // Actionable report fields
  actionDescription String?    // what action the manager must take
  isDone           Boolean?    // null for SIMPLE; true/false for ACTIONABLE
  doneAt           DateTime?
  doneById         String?
  doneBy           User?       @relation("ResolvedReports", fields: [doneById], references: [id])
  createdAt        DateTime    @default(now())
}

/// Granular attendance finalization — locks attendance per section / per staff / per teacher per day
/// finalizationType: "CLASS" = scopeId is classSectionId (per-section lock); "STAFF" = one staff member; "TEACHER" = one teacher section
/// Exactly one of managerId / teacherId is set (the finalizer)
model AttendanceFinalization {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  branchId           String
  branch             Branch   @relation(fields: [branchId], references: [id])
  managerId          String?
  manager            User?    @relation("FinalizedDays", fields: [managerId], references: [id])
  teacherId          String?
  teacher            User?    @relation("TeacherFinalizedDays", fields: [teacherId], references: [id])
  finalizationType   String   // "CLASS" | "STAFF" | "TEACHER"
  scopeId            String   // courseClassId for CLASS; userId for STAFF/TEACHER
  finalizedAt        DateTime @default(now())

  @@unique([date, branchId, finalizationType, scopeId])
}

/// Monthly snapshot for a class — locks teacher-per-section and student roster for that month
model ClassMonthFinalization {
  id               String      @id @default(cuid())
  courseClassId    String
  courseClass      CourseClass @relation(fields: [courseClassId], references: [id], onDelete: Cascade)
  branchId         String
  branch           Branch      @relation(fields: [branchId], references: [id])
  monthNumber      Int
  finalizedAt      DateTime    @default(now())
  finalizedById    String
  finalizedBy      User        @relation("FinalizedClassMonths", fields: [finalizedById], references: [id])
  sectionsSnapshot Json        // [{sectionNumber, sectionName, teacherId, teacherName}] at time of finalization
  studentsSnapshot Json        // [{studentId, studentDbId, firstName, lastName}] at time of finalization

  @@unique([courseClassId, monthNumber])
}

/// Monthly salary payment for STAFF and MANAGER role users
/// dueDate = monthly anniversary of their join date
model StaffPayment {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation("UserStaffPayments", fields: [userId], references: [id])
  branchId        String
  branch          Branch             @relation(fields: [branchId], references: [id])
  dueDate         DateTime           @db.Date  // monthly anniversary date
  periodStart     DateTime           @db.Date  // period covered start
  periodEnd       DateTime           @db.Date  // period covered end
  grossAmount     Float              // salary snapshot at payment time
  deduction       Float              @default(0)
  deductionReason String?
  memo            String?
  netAmount       Float              // grossAmount - deduction
  status          StaffPaymentStatus @default(DRAFT)
  pdfGeneratedAt  DateTime?
  finalizedAt     DateTime?
  finalizedById   String?
  finalizedBy     User?              @relation("StaffPaymentFinalizer", fields: [finalizedById], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId, dueDate])
}

/// Monthly payment for TEACHER role users
/// month + year = calendar month being paid
model TeacherPayment {
  id              String              @id @default(cuid())
  teacherId       String
  teacher         User                @relation("UserTeacherPayments", fields: [teacherId], references: [id])
  branchId        String
  branch          Branch              @relation(fields: [branchId], references: [id])
  month           Int                 // 1-12 calendar month
  year            Int
  paymentType     PaymentType         // snapshot of teacher's payment type at time of payment
  grossAmount     Float
  deduction       Float               @default(0)
  deductionReason String?
  memo            String?
  netAmount       Float
  status          TeacherPaymentStatus @default(DRAFT)
  pdfGeneratedAt  DateTime?
  finalizedAt     DateTime?
  finalizedById   String?
  finalizedBy     User?               @relation("TeacherPaymentFinalizer", fields: [finalizedById], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  sections        TeacherPaymentSection[]
  paidClassMonths TeacherPaymentClassMonth[]

  @@unique([teacherId, month, year])
}

/// Line item for PER_CLASS and FIXED_HOURS teacher payments — one row per section
model TeacherPaymentSection {
  id               String         @id @default(cuid())
  teacherPaymentId String
  teacherPayment   TeacherPayment @relation(fields: [teacherPaymentId], references: [id], onDelete: Cascade)
  classSectionId   String
  courseClassId    String
  classNameSnapshot String        // class name at time of payment
  sectionLabel     String         // section name/number at time of payment
  sessionsCount    Int            // number of sessions this teacher was present for this section
  rateSnapshot     Float          // perClassRate or hourlyRate at time of payment
  amount           Float          // sessionsCount × rateSnapshot
}

/// Line item for REVENUE_PERCENTAGE teacher payments — one row per finalized class-month
/// @@unique prevents double-paying the same class-month for the same teacher
model TeacherPaymentClassMonth {
  id               String         @id @default(cuid())
  teacherPaymentId String
  teacherPayment   TeacherPayment @relation(fields: [teacherPaymentId], references: [id], onDelete: Cascade)
  teacherId        String         // denormalized for unique check
  courseClassId    String
  classNameSnapshot String
  monthNumber      Int
  totalFeesAmount  Float          // total student fees collected for this class-month
  percentageSnapshot Float        // teacher's revenuePercentage at time of payment
  sectionsInClass  Int            // total sections in the class (for context)
  teacherSections  Int            // how many sections this teacher teaches in this class
  amount           Float          // totalFeesAmount × (percentageSnapshot / 100)

  @@unique([teacherId, courseClassId, monthNumber])
}
